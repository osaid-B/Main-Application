# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
#
# When BOTH variables are set, the app uses Supabase (real PostgreSQL backend).
# When either is missing, the app falls back to mock data (localStorage).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Optional ──────────────────────────────────────────────────────────────────
# Uncomment to override the app title shown in the browser tab
# VITE_APP_NAME=Atlas ERP
